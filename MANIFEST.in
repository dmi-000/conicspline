# MANIFEST.in — controls what goes into the sdist (source tarball).
# The wheel is governed by pyproject.toml [tool.setuptools] py-modules
# and always contains only conicspline.py.

# Library
include conicspline.py

# License
include LICENSE

# Documentation
include README.md
include conicspline_doc.md
include DESIGN_HISTORY.md

# Demo and visualization scripts
include blend_demo.py
include show_all_curves.py
include demo_n_transitions.py

# CI
recursive-include .github *.yml

# Regression and diagnostic scripts
include scan_all_curves.py
include test_cross_guard.py
include check_devs.py
include diag_xbranch.py

# Test suite
recursive-include tests *.py

# Development debris (session snapshots, probe scripts, personal notes) is not
# listed above and is therefore excluded automatically.
