      import numpy as np, importlib.util
      from conicspline import fit_conic
      spec = importlib.util.spec_from_file_location('bd', 'blend_demo.py')
      bd = importlib.util.module_from_spec(spec); spec.loader.exec_module(bd)

      def ellipse(t):
          a, b, theta = 3.0, 1.5, np.radians(37)
          xe = a*np.cos(t); ye = b*np.sin(t)
          return xe*np.cos(theta)-ye*np.sin(theta), xe*np.sin(theta)+ye*np.cos(theta)

      t_range = (0.2, 2.5); n = 20
      pts, times = bd.sample_curve(ellipse, t_range, n)
      _, _, _, wins, ms, me, methods = bd._run_blend(pts, times, False, 2)
      output, _ = bd.blend_curve(pts, times, wins, ms, me, N_order=2, N_dense=100)
      xs, ys = output[:,0], output[:,1]
      # Global conic coefficients
      A,B,C,D,E,F = fit_conic(pts[:,:2])
      residuals = np.abs(A*xs**2 + B*xs*ys + C*ys**2 + D*xs + E*ys + F)
      print(f'Tilted ellipse (b=1.5): max algebraic residual = {np.max(residuals):.2e}')
      print(f'methods: {set(methods)}')

      # Near-circle ellipse (b=2.9)
      def ellipse_nc(t):
          a, b, theta = 3.0, 2.9, np.radians(37)
          xe = a*np.cos(t); ye = b*np.sin(t)
          return xe*np.cos(theta)-ye*np.sin(theta), xe*np.sin(theta)+ye*np.cos(theta)
      pts2, times2 = bd.sample_curve(ellipse_nc, t_range, n)
      _, _, _, wins2, ms2, me2, methods2 = bd._run_blend(pts2, times2, False, 2)
      output2, _ = bd.blend_curve(pts2, times2, wins2, ms2, me2, N_order=2, N_dense=100)
      xs2, ys2 = output2[:,0], output2[:,1]
      A2,B2,C2,D2,E2,F2 = fit_conic(pts2[:,:2])
      res2 = np.abs(A2*xs2**2 + B2*xs2*ys2 + C2*ys2**2 + D2*xs2 + E2*ys2 + F2)
      print(f'Near-circle ellipse (b=2.9): max algebraic residual = {np.max(res2):.2e}')
      print(f'methods: {set(methods2)}')
